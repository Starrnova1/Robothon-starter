<mujoco model="egg_pick_place">
  <compiler angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.85 0.85 0.85" rgb2="0.7 0.7 0.7" width="512" height="512"/>
    <material name="table_mat" texture="grid" texrepeat="4 4" reflectance="0.1"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.5 0.5 0.5 1"
          contype="1" conaffinity="1"/>

    <!-- Table -->
    <geom name="table_top" type="box" size="0.5 0.4 0.015"
          pos="0.15 0 0.745" material="table_mat"
          contype="1" conaffinity="1"/>
    <geom name="leg1" type="cylinder" size="0.02 0.37" pos="-0.30  0.35 0.375" rgba="0.6 0.5 0.4 1"/>
    <geom name="leg2" type="cylinder" size="0.02 0.37" pos=" 0.60  0.35 0.375" rgba="0.6 0.5 0.4 1"/>
    <geom name="leg3" type="cylinder" size="0.02 0.37" pos="-0.30 -0.35 0.375" rgba="0.6 0.5 0.4 1"/>
    <geom name="leg4" type="cylinder" size="0.02 0.37" pos=" 0.60 -0.35 0.375" rgba="0.6 0.5 0.4 1"/>

    <!-- Cameras -->
    <camera name="side_cam" pos="0.15 -0.85 1.1" xyaxes="1 0 0 0 0.45 1"/>
    <camera name="top_cam"  pos="0.15  0.0  1.65" xyaxes="1 0 0 0 1 0"/>

    <!-- Lights -->
    <light name="main" pos="0.2 0 2.0" dir="0 0 -1"
           diffuse="0.7 0.7 0.7" specular="0.2 0.2 0.2"/>
    <light name="fill" pos="-0.8 0 1.5" dir="1 0 -1"
           diffuse="0.3 0.3 0.3"/>

    <!-- Egg: placed in front of arm -->
    <body name="egg" pos="0.26 0.0 0.800">
      <freejoint name="egg_free"/>
      <geom name="egg_geom"
            type="ellipsoid"
            size="0.025 0.022 0.032"
            mass="0.065"
            friction="0.8 0.1 0.005"
            condim="4"
            rgba="1.0 0.98 0.85 1"
            contype="1" conaffinity="1"/>
      <site name="egg_center" size="0.005" rgba="1 1 0 0.5"/>
    </body>

    <!-- Bowl: placed to the side of arm so joint1 only needs ~70 deg rotation -->
    <body name="bowl" pos="0.08 0.22 0.760">
      <geom name="bowl_floor" type="cylinder" size="0.055 0.006"
            pos="0 0 0" rgba="0.65 0.32 0.12 1" contype="1" conaffinity="1"/>
      <geom name="bowl_wall_f" type="box" size="0.055 0.006 0.018"
            pos="0  0.058 0.014" rgba="0.65 0.32 0.12 1" contype="1" conaffinity="1"/>
      <geom name="bowl_wall_b" type="box" size="0.055 0.006 0.018"
            pos="0 -0.058 0.014" rgba="0.65 0.32 0.12 1" contype="1" conaffinity="1"/>
      <geom name="bowl_wall_l" type="box" size="0.006 0.055 0.018"
            pos="-0.058 0 0.014" rgba="0.65 0.32 0.12 1" contype="1" conaffinity="1"/>
      <geom name="bowl_wall_r" type="box" size="0.006 0.055 0.018"
            pos=" 0.058 0 0.014" rgba="0.65 0.32 0.12 1" contype="1" conaffinity="1"/>
      <site name="bowl_center" size="0.008" pos="0 0 0.018" rgba="0 1 0 0.7"/>
    </body>

    <!-- Robot arm: centered at table origin -->
    <body name="arm_mount" pos="0.0 0 0.760">
      <include file="arm_bodies.xml"/>
    </body>
  </worldbody>

  <equality>
    <!-- Mirror right finger to left finger -->
    <joint name="finger_mirror"
           joint1="finger_left_joint"
           joint2="finger_right_joint"
           polycoef="0 1 0 0 0"/>
  </equality>

  <actuator>
    <position name="act_j1"   joint="joint1"            kp="50" ctrlrange="-3.14 3.14"/>
    <position name="act_j2"   joint="joint2"            kp="50" ctrlrange="-1.57 1.57"/>
    <position name="act_j3"   joint="joint3"            kp="50" ctrlrange="-2.0  2.0"/>
    <position name="act_grip" joint="finger_left_joint" kp="20" ctrlrange="0 0.035"/>
  </actuator>

  <sensor>
    <actuatorfrc name="grip_force" actuator="act_grip"/>
    <actuatorfrc name="j1_torque"  actuator="act_j1"/>
    <actuatorfrc name="j2_torque"  actuator="act_j2"/>
    <actuatorfrc name="j3_torque"  actuator="act_j3"/>
  </sensor>

</mujoco>
